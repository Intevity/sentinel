{
  "name": "claude-sentinel",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "build:app": "node scripts/build-app.mjs",
    "build:app:release": "pnpm --filter @claude-sentinel/app run tauri:build",
    "install:app": "node scripts/build-app.mjs",
    "dev": "pnpm -r --parallel dev",
    "test": "vitest run --coverage --reporter=verbose",
    "test:watch": "vitest",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "security:test": "node scripts/security-test.mjs",
    "alerts:test": "node scripts/alerts-test.mjs",
    "mock:budget": "node scripts/mock-budget.mjs",
    "mock:budget:update": "node scripts/mock-budget.mjs --update",
    "icons:generate": "node scripts/generate-ico.mjs",
    "icons:verify": "node scripts/generate-ico.mjs --verify",
    "bench:compression": "SENTINEL_BENCH_TABLE=1 vitest run packages/daemon/bench/compression-bench.test.ts --reporter=basic"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.0.0",
    "sharp": "^0.33.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp"
    ]
  }
}

{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@claude-sentinel/shared": ["../shared/src/index.ts"]
    },
    "types": ["react", "react-dom"]
  },
  "include": ["src/**/*"],
  "exclude": ["src-tauri", "dist", "node_modules"]
}

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sentinel",
  "identifier": "com.jeffwooden.claude-sentinel",
  "version": "0.1.0",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --filter @sentinel/shared run build && pnpm --filter @sentinel/test-harness run build && pnpm --filter @sentinel/daemon build && pnpm --filter @sentinel/daemon build:sidecar && pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Sentinel",
        "width": 580,
        "height": 628,
        "minWidth": 580,
        "maxWidth": 580,
        "minHeight": 288,
        "maxHeight": 628,
        "resizable": false,
        "decorations": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/sentinel-daemon"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "Info.plist",
      "entitlements": "entitlements.plist"
    },
    "windows": {
      "nsis": {
        "installerHooks": "./windows/hooks.nsh"
      },
      "wix": {
        "fragmentPaths": ["./windows/daemon-close.wxs"],
        "componentRefs": ["DaemonCloseMarker"]
      }
    }
  },
  "plugins": {
    "notification": null,
    "store": null,
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENGRTlGOEQ5QTQzQTczMDQKUldRRWN6cWsyZmpweitHcTVPeHlQVlVwTE5hd3pXcGdCK3k5NTBSQUR1Tlp4Qmh3VHd6TVE2dnIK",
      "endpoints": [
        "https://REPLACE_WITH_S3_OR_CDN_HOST/stable/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}

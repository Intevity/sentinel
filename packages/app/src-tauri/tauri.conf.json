{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Sentinel",
  "identifier": "com.jeffwooden.claude-sentinel",
  "version": "0.1.0",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --filter @claude-sentinel/daemon build && pnpm --filter @claude-sentinel/daemon build:sidecar && pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Claude Sentinel",
        "width": 420,
        "height": 600,
        "resizable": true,
        "decorations": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/claude-sentinel-daemon"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    }
  },
  "plugins": {
    "notification": null,
    "store": null
  }
}

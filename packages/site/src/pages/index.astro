---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import FeatureCarousel from '../components/FeatureCarousel.tsx';
import FeatureGrid from '../components/FeatureGrid.astro';
import Privacy from '../components/Privacy.astro';
import Download from '../components/Download.astro';
import Footer from '../components/Footer.astro';
import { features } from '../data/features';

const base = import.meta.env.BASE_URL;
---

<Base>
  <Nav />
  <main id="main">
    <Hero />

    <section id="features" class="section pt-4">
      <div class="mb-10 text-center">
        <p class="section-label">See it in action</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
          A guided tour of every tab
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-foreground/60">
          Pick a feature to watch a short demo. The carousel advances on its own; hover to pause.
        </p>
      </div>
      <FeatureCarousel client:visible features={features} base={base} />
    </section>

    <FeatureGrid />
    <Privacy />
    <Download />
  </main>
  <Footer />
</Base>

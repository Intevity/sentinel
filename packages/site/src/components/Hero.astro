---
import Icon from './Icon.astro';

const base = import.meta.env.BASE_URL;
const asset = (p: string) => `${base.replace(/\/$/, '')}/${p.replace(/^\//, '')}`;
const repo = 'https://github.com/Intevity/sentinel';
const releases = `${repo}/releases/latest`;
---

<section id="top" class="hero-gradient relative overflow-hidden">
  <div class="section flex flex-col items-center pb-12 pt-20 text-center sm:pt-28">
    <span
      class="mb-6 inline-flex items-center gap-2 rounded-full border border-border-subtle/15 px-3.5 py-1.5 text-xs font-medium text-foreground/70"
    >
      <span class="h-1.5 w-1.5 rounded-full bg-ios-green"></span>
      Open source. Local first. No telemetry.
    </span>

    <img
      src={asset('sentinel-mascot.png')}
      alt="Sentinel mascot"
      width="96"
      height="96"
      class="mb-6 h-24 w-24 drop-shadow-[0_8px_30px_rgba(0,122,255,0.35)]"
    />

    <h1 class="max-w-4xl text-display font-bold tracking-tight text-foreground">
      One control panel for every Claude account
    </h1>

    <p class="mt-6 max-w-2xl text-lg leading-relaxed text-foreground/70 sm:text-xl">
      Sentinel combines the accounts you own, rotates tokens automatically, scans every
      request for secrets and risky tool calls, shows the rate limits Claude Code hides, and caps
      overage spend before it runs away.
    </p>

    <div class="mt-9 flex flex-col items-center gap-3 sm:flex-row">
      <a href="#download" class="btn-primary cta-glow px-7 py-3.5 text-base">
        <Icon name="download" size={18} />
        Download for free
      </a>
      <a href={repo} class="btn-ghost px-7 py-3.5 text-base" rel="noopener" target="_blank">
        <Icon name="github" size={18} />
        Star on GitHub
      </a>
    </div>

    <p class="mt-5 text-sm text-foreground/50">macOS, Windows, and Linux. MIT licensed.</p>
    <p class="sr-only">
      <a href={releases}>Latest release downloads</a>
    </p>
  </div>
</section>

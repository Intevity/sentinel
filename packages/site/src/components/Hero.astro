---
import Icon from './Icon.astro';

const base = import.meta.env.BASE_URL;
const asset = (p: string) => `${base.replace(/\/$/, '')}/${p.replace(/^\//, '')}`;
const repo = 'https://github.com/Intevity/sentinel';
const releases = `${repo}/releases/latest`;
---

<section id="top" class="hero-gradient relative overflow-hidden">
  <div class="section relative z-10 flex flex-col items-center pb-12 pt-20 text-center sm:pt-28">
    <span
      class="hero-rise mb-6 inline-flex items-center gap-2 rounded-full border border-border-subtle/15 px-3.5 py-1.5 text-xs font-medium text-foreground/70"
    >
      <span class="h-1.5 w-1.5 rounded-full bg-ios-green"></span>
      Open source. Local first. No telemetry.
    </span>

    <div class="mascot-stage mb-6">
      <span class="mascot-glow" aria-hidden="true"></span>
      <span class="mascot-sonar" aria-hidden="true">
        <span class="mascot-ring"></span>
        <span class="mascot-ring"></span>
        <span class="mascot-ring"></span>
      </span>
      <img
        src={asset('sentinel-mascot.png')}
        alt="Sentinel mascot"
        width="96"
        height="96"
        class="mascot-img h-24 w-24"
      />
    </div>

    <h1
      class="hero-rise max-w-4xl text-display font-bold tracking-tight text-foreground"
      style="animation-delay: 0.12s"
    >
      One control panel for every Claude account
    </h1>

    <p
      class="hero-rise mt-6 max-w-2xl text-lg leading-relaxed text-foreground/70 sm:text-xl"
      style="animation-delay: 0.2s"
    >
      Sentinel brings the Claude accounts you own into one place and switches between them for you,
      scans and sandboxes every request for secrets and risky tool calls, cuts the tokens your
      sessions waste, and catches overage spend before it runs away.
    </p>

    <div
      class="hero-rise mt-9 flex flex-col items-center gap-3 sm:flex-row"
      style="animation-delay: 0.28s"
    >
      <a href="#download" class="btn-primary cta-glow px-7 py-3.5 text-base">
        <Icon name="download" size={18} />
        Download for free
      </a>
      <a href={repo} class="btn-ghost px-7 py-3.5 text-base" rel="noopener" target="_blank">
        <Icon name="github" size={18} />
        Star on GitHub
      </a>
    </div>

    <p class="hero-rise mt-5 text-sm text-foreground/50" style="animation-delay: 0.36s">
      macOS, Windows, and Linux. MIT licensed.
    </p>
    <p class="sr-only">
      <a href={releases}>Latest release downloads</a>
    </p>
  </div>
</section>

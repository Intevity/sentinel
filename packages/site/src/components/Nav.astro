---
import Icon from './Icon.astro';

const base = import.meta.env.BASE_URL;
const asset = (p: string) => `${base.replace(/\/$/, '')}/${p.replace(/^\//, '')}`;
const repo = 'https://github.com/Intevity/claude-sentinel';
---

<header class="sticky top-0 z-40 border-b border-border-subtle/10 bg-[#111111]/70 backdrop-blur-xs">
  <nav class="mx-auto flex w-full max-w-6xl items-center justify-between px-6 py-3">
    <a href="#top" class="flex items-center gap-2.5">
      <img src={asset('sentinel-mascot.png')} alt="" width="28" height="28" class="rounded-lg" />
      <span class="text-sm font-semibold tracking-tight text-foreground">Claude Sentinel</span>
    </a>
    <div class="flex items-center gap-1 sm:gap-2">
      <a
        href="#features"
        class="hidden rounded-full px-3 py-2 text-sm font-medium text-foreground/70 transition hover:text-foreground sm:inline-flex"
      >
        Features
      </a>
      <a
        href="#download"
        class="hidden rounded-full px-3 py-2 text-sm font-medium text-foreground/70 transition hover:text-foreground sm:inline-flex"
      >
        Download
      </a>
      <a href={repo} class="btn-ghost px-4 py-2" rel="noopener" target="_blank">
        <Icon name="github" size={16} />
        GitHub
      </a>
    </div>
  </nav>
</header>

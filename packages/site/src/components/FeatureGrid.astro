---
import Icon from './Icon.astro';
import { features } from '../data/features';
---

<section class="section has-aurora">
  <div class="section-aurora" aria-hidden="true"></div>
  <div class="mb-12 text-center">
    <p class="section-label">Everything in one tray</p>
    <h2 class="mt-3 text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
      Six jobs Claude Code leaves to you
    </h2>
    <p class="mx-auto mt-4 max-w-2xl text-foreground/60">
      Sentinel sits between Claude Code and Anthropic as a local proxy, so it can see and act on
      every request without ever sending your data anywhere else.
    </p>
  </div>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {
      features.map((f) => (
        <article class="glass-card flex flex-col gap-3 p-6">
          <span class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-ios-blue/10 text-ios-blue">
            <Icon name={f.icon} size={22} />
          </span>
          <h3 class="text-base font-semibold text-foreground">{f.title}</h3>
          <p class="text-sm leading-relaxed text-foreground/60">{f.description}</p>
        </article>
      ))
    }
  </div>
</section>

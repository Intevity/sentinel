---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Sentinel: one control panel for every Claude account',
  description = 'An open-source Claude Code companion: manage the Claude accounts you own and switch between them, scan and sandbox every request for secrets and risky tool calls, cut wasted tokens, and catch overage spend before it runs away. Your data never leaves your machine.',
} = Astro.props;

const base = import.meta.env.BASE_URL;
// Astro's BASE_URL carries a trailing slash; join without doubling it.
const asset = (p: string) => `${base.replace(/\/$/, '')}/${p.replace(/^\//, '')}`;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = asset('sentinel-mascot.png');
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href={asset('favicon.png')} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body class="font-sans text-foreground antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-full focus:bg-ios-blue focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-white"
    >
      Skip to content
    </a>
    <slot />
  </body>
</html>

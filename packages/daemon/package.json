{
  "name": "@sentinel/daemon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "sentinel": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "build:sidecar": "node scripts/build-sidecar.mjs",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sandbox-runtime": "^0.0.59",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@sentinel/shared": "workspace:*",
    "better-sqlite3": "^12.0.0"
  },
  "devDependencies": {
    "@sentinel/test-harness": "workspace:*",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^24.0.0",
    "@yao-pkg/pkg": "^6.19.0",
    "esbuild": "^0.21.0",
    "typescript": "*",
    "vitest": "*"
  }
}
